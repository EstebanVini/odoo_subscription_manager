<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Kanban View (Main View) -->
    <record id="subscription_subscriber_view_kanban" model="ir.ui.view">
        <field name="name">subscription.subscriber.kanban</field>
        <field name="model">subscription.subscriber</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column"
                    quick_create="false" records_draggable="true"
                    group_create="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="partner_email"/>
                <field name="state"/>
                <field name="subscription_count"/>
                <field name="total_monthly_amount"/>
                <field name="currency_id"/>
                <field name="pending_invoice_amount"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_details d-flex flex-column gap-1">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title">
                                    <field name="partner_id"/>
                                </strong>
                            </div>
                            <div class="text-muted small">
                                <field name="name"/>
                            </div>
                            <div class="small">
                                <span class="fw-bold">
                                    <field name="subscription_count"/>
                                </span>
                                <span class="text-muted"> active subscription(s)</span>
                            </div>
                            <div class="small">
                                <span class="text-muted">Amount: </span>
                                <field name="total_monthly_amount" widget="monetary"/>
                            </div>
                            <div t-if="record.pending_invoice_amount.raw_value > 0"
                                 class="small text-danger fw-bold">
                                <span>Pending: </span>
                                <field name="pending_invoice_amount" widget="monetary"/>
                            </div>
                            <div class="small text-muted" t-if="record.partner_email.value">
                                <i class="fa fa-envelope-o me-1"/>
                                <field name="partner_email"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="subscription_subscriber_view_form" model="ir.ui.view">
        <field name="name">subscription.subscriber.form</field>
        <field name="model">subscription.subscriber</field>
        <field name="arch" type="xml">
            <form string="Subscriber">
                <header>
                    <button name="action_activate" string="Activate"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_open_payment_wizard" string="Register Payment"
                            type="object" class="btn-primary"
                            invisible="state not in ('active', 'pending_payment', 'paused')"/>
                    <button name="action_pause" string="Pause"
                            type="object"
                            invisible="state not in ('active', 'pending_payment')"
                            confirm="Are you sure you want to pause all subscriptions?"/>
                    <button name="action_activate" string="Reactivate"
                            type="object" class="btn-primary"
                            invisible="state != 'paused'"/>
                    <button name="action_finalize" string="Finalize"
                            type="object"
                            invisible="state in ('draft', 'done')"
                            confirm="This will cancel all subscriptions. Continue?"/>
                    <button name="action_draft" string="Reset to Draft"
                            type="object"
                            invisible="state != 'done'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o">
                            <field name="invoice_count" widget="statbutton"
                                   string="Invoices"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Subscriber Information">
                            <field name="partner_id"/>
                            <field name="partner_email"/>
                            <field name="partner_phone"/>
                        </group>
                        <group string="Summary">
                            <field name="subscription_count"/>
                            <field name="total_monthly_amount"/>
                            <field name="pending_invoice_amount"
                                   decoration-danger="pending_invoice_amount > 0"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Subscriptions" name="subscriptions">
                            <field name="subscription_line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="plan_id"/>
                                    <field name="start_date"/>
                                    <field name="next_invoice_date"/>
                                    <field name="end_date" optional="hide"/>
                                    <field name="grace_days" optional="hide"/>
                                    <field name="penalty_amount" optional="hide"/>
                                    <field name="reminder_days_before" optional="hide"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'active'"
                                           decoration-warning="state == 'pending_payment'"
                                           decoration-danger="state == 'paused'"
                                           decoration-info="state == 'draft'"
                                           decoration-muted="state == 'cancelled'"/>
                                    <field name="invoice_count" string="Invoices"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                    <field name="active" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="subscription_subscriber_view_tree" model="ir.ui.view">
        <field name="name">subscription.subscriber.tree</field>
        <field name="model">subscription.subscriber</field>
        <field name="arch" type="xml">
            <tree string="Subscribers" multi_edit="1">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="partner_email"/>
                <field name="subscription_count"/>
                <field name="total_monthly_amount" widget="monetary" sum="Total"/>
                <field name="pending_invoice_amount" widget="monetary"
                       decoration-danger="pending_invoice_amount > 0" sum="Pending"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'pending_payment'"
                       decoration-danger="state == 'paused'"
                       decoration-info="state == 'draft'"
                       decoration-muted="state == 'done'"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                <field name="currency_id" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="subscription_subscriber_view_search" model="ir.ui.view">
        <field name="name">subscription.subscriber.search</field>
        <field name="model">subscription.subscriber</field>
        <field name="arch" type="xml">
            <search string="Subscribers">
                <field name="name"/>
                <field name="partner_id"/>
                <separator/>
                <filter string="Draft" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active_state"
                        domain="[('state', '=', 'active')]"/>
                <filter string="Pending Payment" name="pending_payment"
                        domain="[('state', '=', 'pending_payment')]"/>
                <filter string="Paused" name="paused"
                        domain="[('state', '=', 'paused')]"/>
                <filter string="Finalized" name="done"
                        domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Partner" name="group_partner"
                            context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Main Action (Kanban first) -->
    <record id="action_subscription_subscriber" model="ir.actions.act_window">
        <field name="name">Subscribers</field>
        <field name="res_model">subscription.subscriber</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="subscription_subscriber_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first subscriber
            </p>
            <p>
                Create subscribers linked to portal users and assign
                subscription plans for automated recurring billing.
            </p>
        </field>
    </record>

</odoo>
