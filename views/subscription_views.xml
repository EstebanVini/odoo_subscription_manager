<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_subscription_subscriber_kanban" model="ir.ui.view">
        <field name="name">subscription.subscriber.kanban</field>
        <field name="model">subscription.subscriber</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column" sample="1">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="stage_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="partner_id"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom mt-2">
                                <div class="oe_kanban_bottom_left">
                                    <i class="fa fa-cubes me-1" title="Suscripciones"/>
                                    <field name="subscription_ids" widget="statinfo"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <button name="action_open_payment_wizard" type="object" class="btn btn-sm btn-primary">
                                        Pagar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_subscription_subscriber_form" model="ir.ui.view">
        <field name="name">subscription.subscriber.form</field>
        <field name="model">subscription.subscriber</field>
        <field name="arch" type="xml">
            <form string="Gestión de Suscriptor">
                <header>
                    <button name="action_open_payment_wizard" string="Registrar Pago Múltiple" type="object" class="oe_highlight"/>
                    <field name="stage_id" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="partner_id" placeholder="Seleccione el Cliente/Usuario..." options="{'no_create': True}"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" readonly="1" help="Usuario de portal vinculado automáticamente."/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Planes Contratados" name="subscriptions">
                            <field name="subscription_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="price"/>
                                    <field name="interval"/>
                                    <field name="interval_type"/>
                                    <field name="next_invoice_date"/>
                                    <field name="penalty_days"/>
                                    <field name="penalty_amount"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_subscription_subscriber" model="ir.actions.act_window">
        <field name="name">Suscriptores</field>
        <field name="res_model">subscription.subscriber</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Añade tu primer Suscriptor
            </p>
            <p>
                Gestiona la recurrencia, facturación y pagos de tus clientes desde aquí.
            </p>
        </field>
    </record>

    <menuitem id="menu_subscription_root" 
              name="Suscripciones" 
              sequence="40"/>
              
    <menuitem id="menu_subscription_dashboard" 
              name="Tablero Kanban" 
              parent="menu_subscription_root" 
              action="action_subscription_subscriber" 
              sequence="10"/>

</odoo>