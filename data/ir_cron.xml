<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Cron 1: Generate invoices for active subscriptions -->
    <record id="ir_cron_generate_invoices" model="ir.cron">
        <field name="name">Subscriptions: Generate Invoices</field>
        <field name="model_id" ref="model_subscription_subscription"/>
        <field name="state">code</field>
        <field name="code">model._cron_generate_invoices()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="doall">False</field>
    </record>

    <!-- Cron 2: Check overdue invoices and move to Pending Payment -->
    <record id="ir_cron_check_overdue" model="ir.cron">
        <field name="name">Subscriptions: Check Overdue Invoices</field>
        <field name="model_id" ref="model_subscription_subscription"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_overdue()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="doall">False</field>
    </record>

    <!-- Cron 3: Check grace period and pause subscriptions -->
    <record id="ir_cron_check_grace_period" model="ir.cron">
        <field name="name">Subscriptions: Check Grace Period and Apply Penalties</field>
        <field name="model_id" ref="model_subscription_subscription"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_grace_period()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="doall">False</field>
    </record>

    <!-- Cron 4: Send payment reminders before due date -->
    <record id="ir_cron_send_payment_reminders" model="ir.cron">
        <field name="name">Subscriptions: Send Payment Reminders</field>
        <field name="model_id" ref="model_subscription_subscription"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_payment_reminders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="doall">False</field>
    </record>

</odoo>
