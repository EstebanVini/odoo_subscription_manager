<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <record id="email_template_upcoming_payment" model="mail.template">
            <field name="name">Suscripción: Recordatorio Próximo Pago</field>
            <field name="model_id" ref="odoo_subscription_management.model_subscription_record"/>
            <field name="subject">Recordatorio de pago próximo para su suscripción: {{ object.product_id.name }}</field>
            <field name="email_from">{{ (object.env.company.email_formatted or object.env.user.email_formatted) }}</field>
            <field name="email_to">{{ object.subscriber_id.partner_id.email_formatted }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Hola <t t-out="object.subscriber_id.partner_id.name or ''"/>,<br/><br/>
                        Le recordamos que su suscripción al plan <strong><t t-out="object.product_id.name or ''"/></strong> 
                        se renovará el próximo <strong><t t-out="object.next_invoice_date or ''"/></strong>.<br/><br/>
                        El monto a facturar será de <t t-out="object.price or 0.0"/>.<br/><br/>
                        Gracias por confiar en nosotros.
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <record id="email_template_late_payment" model="mail.template">
            <field name="name">Suscripción: Aviso Falta de Pago</field>
            <field name="model_id" ref="odoo_subscription_management.model_subscription_record"/>
            <field name="subject">Aviso Urgente: Pago pendiente de su suscripción {{ object.product_id.name }}</field>
            <field name="email_from">{{ (object.env.company.email_formatted or object.env.user.email_formatted) }}</field>
            <field name="email_to">{{ object.subscriber_id.partner_id.email_formatted }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Hola <t t-out="object.subscriber_id.partner_id.name or ''"/>,<br/><br/>
                        Hemos detectado que el pago de su suscripción <strong><t t-out="object.product_id.name or ''"/></strong> 
                        se encuentra vencido.<br/><br/>
                        Le invitamos a regularizar su situación lo antes posible para evitar la suspensión del servicio 
                        y la aplicación de penalizaciones.<br/><br/>
                        Si ya realizó el pago, por favor haga caso omiso a este mensaje.
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>