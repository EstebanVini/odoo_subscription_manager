<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_subscription" model="ir.module.category">
        <field name="name">Subscriptions</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_subscription_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_subscription"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_subscription_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_subscription"/>
        <field name="implied_ids" eval="[(4, ref('group_subscription_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <!-- Multi-Company Rules -->
    <record id="rule_subscription_subscriber_company" model="ir.rule">
        <field name="name">Subscription Subscriber: Multi-Company</field>
        <field name="model_id" ref="model_subscription_subscriber"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[
            '|',
            ('company_id', '=', False),
            ('company_id', 'in', company_ids)
        ]</field>
    </record>

    <record id="rule_subscription_plan_company" model="ir.rule">
        <field name="name">Subscription Plan: Multi-Company</field>
        <field name="model_id" ref="model_subscription_plan"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[
            '|',
            ('company_id', '=', False),
            ('company_id', 'in', company_ids)
        ]</field>
    </record>

    <record id="rule_subscription_line_company" model="ir.rule">
        <field name="name">Subscription Line: Multi-Company</field>
        <field name="model_id" ref="model_subscription_line"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[
            '|',
            ('company_id', '=', False),
            ('company_id', 'in', company_ids)
        ]</field>
    </record>
</odoo>
