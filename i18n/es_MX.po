msgid ""
"<div style=\"margin: 0; padding: 0; font-family: Arial, sans-serif;\">\n"
"    <p>Dear {{ object.subscriber_id.partner_id.name }},</p>\n"
"    <p style=\"color: #d32f2f;\">\n"
"        <strong>Your payment for {{ object.plan_id.name }} is overdue.</strong>\n"
"        Your subscription has been placed on <strong>Pending Payment</strong> status.\n"
"    </p>\n"
"    <table style=\"border-collapse: collapse; width: 100%; margin: 16px 0;\">\n"
"        <tr style=\"background-color: #fce4e4;\">\n"
