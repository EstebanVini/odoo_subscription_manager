#. module: odoo_subscription_manager
#: model:mail.template,body_html:odoo_subscription_manager.email_template_payment_reminder
msgid ""
"<div style=\"margin: 0; padding: 0; font-family: Arial, sans-serif;\">\n"
"    <p>Dear {{ object.subscriber_id.partner_id.name }},</p>\n"
"    <p>\n"
"        This is a friendly reminder that your upcoming payment for\n"
"        <strong>{{ object.plan_id.name }}</strong> is due on\n"
"        <strong>{{ object.date_next_invoice }}</strong>.\n"
"    </p>\n"
"    <table style=\"border-collapse: collapse; width: 100%; margin: 16px 0;\">\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Subscription</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\">{{ object.name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Plan</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\">{{ object.plan_id.name }}</td>\n"
"        </tr>\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Amount</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\">{{ object.price }} {{ object.currency_id.name }}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Due Date</strong></td>\n"
"            <td style=\"padding: 8px; border: 1px solid #ddd;\">{{ object.date_next_invoice }}</td>\n"
"        </tr>\n"
"    </table>\n"
"    <p>Please ensure your payment is made on time to avoid service interruption.</p>\n"
"    <p>Thank you for your continued support.</p>\n"
"    <br/>\n"
"    <p>Best regards,<br/><strong>{{ object.company_id.name }}</strong></p>\n"
"</div>\n"
"        "
