<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="subscription_payment_wizard_view_form" model="ir.ui.view">
        <field name="name">subscription.payment.wizard.form</field>
        <field name="model">subscription.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Subscription Payment">
                <group string="Subscriber">
                    <field name="subscriber_id" readonly="1"/>
                    <field name="subscription_id"
                           options="{'no_create': True, 'no_open': True}"/>
                </group>
                <group string="Invoice" invisible="not invoice_id">
                    <field name="invoice_id"
                           options="{'no_create': True, 'no_open': True}"/>
                    <field name="invoice_date"/>
                    <field name="invoice_date_due"/>
                    <field name="amount_residual"/>
                    <field name="currency_id" invisible="1"/>
                </group>
                <group string="Payment">
                    <field name="journal_id"/>
                    <field name="payment_date"/>
                </group>
                <footer>
                    <button name="action_register_payment"
                            string="Register Payment"
                            type="object"
                            class="btn-primary"
                            invisible="not invoice_id"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
