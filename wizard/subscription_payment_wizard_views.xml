<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_subscription_payment_wizard_form" model="ir.ui.view">
        <field name="name">subscription.payment.wizard.form</field>
        <field name="model">subscription.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar Pago de Suscripción">
                <sheet>
                    <group>
                        <field name="subscriber_id" invisible="1"/>
                        <field name="currency_id" invisible="1"/>
                        
                        <field name="invoice_id" options="{'no_create': True}"/>
                        <field name="journal_id" options="{'no_create': True}"/>
                        <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Pagar y Enviar Correo" name="action_pay" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>